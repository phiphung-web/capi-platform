generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id            String        @id @default(cuid())
  name          String
  description   String?
  createdAt     DateTime      @default(now())
  apiKeys       ApiKey[]
  destinations  Destination[]
  events        Event[]
  sources       Source[]
}

model ApiKey {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id])
  projectId String
  name      String
  key       String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Destination {
  id            String         @id @default(cuid())
  project       Project        @relation(fields: [projectId], references: [id])
  projectId     String
  type          String
  config        Json
  isActive      Boolean        @default(true)
  healthStatus  String         @default("unknown")
  createdAt     DateTime       @default(now())
  deliveryLogs  DeliveryLog[]
}

model Event {
  id            String         @id @default(cuid())
  project       Project        @relation(fields: [projectId], references: [id])
  projectId     String
  sourceRef     Source?        @relation("SourceEvents", fields: [sourceId], references: [id])
  sourceId      String?
  eventName     String
  eventId       String
  eventTime     Int
  source        String
  userJson      Json
  dataJson      Json
  rawPayload    Json?
  qualityScore  Float          @default(0)
  qualityFlags  Json?
  createdAt     DateTime       @default(now())
  deliveryLogs  DeliveryLog[]
}

model DeliveryLog {
  id            String       @id @default(cuid())
  event         Event        @relation(fields: [eventId], references: [id])
  eventId       String
  destination   Destination  @relation(fields: [destinationId], references: [id])
  destinationId String
  status        String
  attempts      Int          @default(0)
  lastResponse  Json?
  lastError     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Source {
  id          String   @id @default(cuid())
  project     Project  @relation(fields: [projectId], references: [id])
  projectId   String
  name        String
  eventKey    String   @unique
  mappingJson Json?
  seenFields  Json?
  createdAt   DateTime @default(now())
  events      Event[]  @relation("SourceEvents")
}
